<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.fengshiqing.springai.dao.SensitiveCategoryMapper">

    <resultMap id="BaseResultMap" type="com.fengshiqing.springai.dao.entity.SensitiveCategory">
            <id property="id" column="id" />
            <result property="categoryName" column="category_name" />
            <result property="createdTime" column="created_time" />
            <result property="updateTime" column="update_time" />
            <result property="status" column="status" />
    </resultMap>

    <sql id="Base_Column_List">
        id,category_name,created_time,update_time,status
    </sql>

    <insert id="insert" parameterType="com.fengshiqing.springai.dao.entity.SensitiveCategory">
        insert into sensitive_category (category_name, created_time, update_time, status)
        values (#{categoryName}, #{createdTime}, #{updateTime}, #{status})
    </insert>

    <delete id="deleteById" parameterType="java.lang.Integer">
        delete from sensitive_category where id = #{id}
    </delete>

    <select id="selectById" parameterType="java.lang.Integer" resultType="com.fengshiqing.springai.dao.entity.SensitiveCategory">
        select * from sensitive_category where id = #{id}
    </select>

    <update id="update" parameterType="com.fengshiqing.springai.dao.entity.SensitiveCategory">
        update sensitive_category
        <set>
            <if test="categoryName != null">category_name = #{categoryName},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="status != null">status = #{status},</if>
        </set>
        where id = #{id}
    </update>

    <select id="selectAll" resultType="com.fengshiqing.springai.dao.entity.SensitiveCategory">
        select * from sensitive_category
    </select>
</mapper>
