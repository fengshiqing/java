<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.fengshiqing.springai.dao.SensitiveCategoryMapper">

    <resultMap id="BaseResultMap" type="com.fengshiqing.springai.dao.entity.SensitiveCategory">
        <id property="id" column="id"/>
        <result property="categoryName" column="category_name"/>
        <result property="createdTime" column="created_time"/>
        <result property="updateTime" column="update_time"/>
        <result property="status" column="status"/>
    </resultMap>

    <select id="selectByCondition" resultMap="BaseResultMap">
        select * from sensitive_category
        <if test="offset != null and pageSize != null">
            limit #{offset}, #{pageSize}
        </if>
    </select>

    <select id="countAll" resultType="long">
        select count(*) from sensitive_category
    </select>

</mapper>
