<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.fengshiqing.springai.dao.SensitiveWordMapper">

    <resultMap id="BaseResultMap" type="com.fengshiqing.springai.dao.entity.SensitiveWord">
            <id property="id" column="id" />
            <result property="word" column="word" />
            <result property="category" column="category" />
            <result property="status" column="status" />
            <result property="createdAt" column="created_at" />
            <result property="updatedAt" column="updated_at" />
    </resultMap>

    <sql id="Base_Column_List">
        id,word,category,status,created_at,updated_at
    </sql>

    <insert id="insert" parameterType="com.fengshiqing.springai.dao.entity.SensitiveWord">
        insert into sensitive_word (word, category, status, created_at, updated_at)
        values (#{word}, #{category}, #{status}, #{createdAt}, #{updatedAt})
    </insert>

    <delete id="deleteById" parameterType="java.lang.Integer">
        delete from sensitive_word where id = #{id}
    </delete>

    <select id="selectById" parameterType="java.lang.Integer" resultType="com.fengshiqing.springai.dao.entity.SensitiveWord">
        select * from sensitive_word where id = #{id}
    </select>

    <update id="update" parameterType="com.fengshiqing.springai.dao.entity.SensitiveWord">
        update sensitive_word
        <set>
            <if test="word != null">word = #{word},</if>
            <if test="category != null">category = #{category},</if>
            <if test="status != null">status = #{status},</if>
            <if test="updatedAt != null">updated_at = #{updatedAt},</if>
        </set>
        where id = #{id}
    </update>

    <select id="selectAll" resultType="com.fengshiqing.springai.dao.entity.SensitiveWord">
        select * from sensitive_word
    </select>
</mapper>
