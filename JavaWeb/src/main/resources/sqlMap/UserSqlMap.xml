<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.kunning.dao.UserDao">

	<select id="queryUser" parameterType="com.kunning.pojo.User" resultType="com.kunning.pojo.User">
		SELECT	username, password
		FROM 	user
		WHERE	1 = 1
		<if test='username!=null or username != ""'>
			AND username = #{username}
		</if>
	</select>

	<insert id="saveUser" parameterType="com.kunning.pojo.User">
		INSERT INTO user
		(
			username, password
		) VALUES(
			#{username}, #{password}
		)
	</insert>

</mapper>
