<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.kunning.springboot.dao">

    <insert id="insert">
        INSERT INTO user
            (username, password)
        VALUES
            (#{username}, #{password})
    </insert>


    <select id="queryAllUser" resultType="com.kunning.springboot.pojo.User">
        SELECT *
          FROM user
         WHERE 1 = 1
    </select>

</mapper>